# CESA Backend v3.5 - Environment Example
# Copy this file to .env and fill in the values

# DATABASE (MariaDB on Oracle VPS)
DB_HOST=144.24.23.61
DB_NAME=cesa_web
DB_USER=cesa_admin
DB_PASS=tu_password_seguro

# HYBRID IA ENGINE
# Cloudflare Tunnel URL for local Mac Mini inference
# Example: https://assistant.ftapps.com
CESA_MAC_MINI_URL=http://localhost:11434

# CLOUD FALLBACKS
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=AIza_your_key_here

# AUTH & SECURITY
# Generate a strong key for JWT signing
JWT_SECRET=cesa_super_secret_change_me_2026
# Allowed domain for CORS validation
ALLOW_ORIGIN=https://cesa.unison.mx

# ENVIRONMENT
APP_ENV=development # production | development

# MAILING SYSTEM (PHPMailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=software@fondothoth.com
SMTP_PASS=tu_app_password
SMTP_FROM=cesa.notificaciones@unison.mx
SMTP_NAME="CESA Institucional"
